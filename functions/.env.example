# SMTP Configuration for Cloud Functions email sending
# Set these using: firebase functions:secrets:set SMTP_USER, etc.
# Or create a .env file in the functions/ directory for local emulator testing.

SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=noreply@your-domain.co.nz
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@your-domain.co.nz
APP_URL=https://your-app-url.web.app
