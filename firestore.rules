rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is the super-admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email.lower() == 'christo@emgroup.co.nz';
    }

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user has access to a specific project
    function hasProjectAccess(projectId) {
      return isAuth() && (
        isAdmin() ||
        projectId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.allowedProjects
      );
    }

    // User profiles: users can read their own, admin can read/write all
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isAuth() && request.auth.uid == userId);
    }

    // Access requests collection
    match /accessRequests/{requestId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // Projects: scoped access based on user's allowedProjects
    match /projects/{projectId} {
      allow read: if hasProjectAccess(projectId);
      allow write: if isAdmin();

      // Subcollections (updates, actions, qa, photos, data)
      match /{collection}/{docId} {
        allow read: if hasProjectAccess(projectId);
        allow create: if hasProjectAccess(projectId);
        allow update, delete: if isAdmin();
      }
    }
  }
}
